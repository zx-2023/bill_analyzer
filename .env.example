# App Configuration
APP_ENV=development
DEBUG=true

# Database
DB_PATH=database/bills.db

# AI Service (Optional)
KIMI_API_KEY=

# Alipay Open Platform Configuration
# Get these from https://open.alipay.com/
ALIPAY_APP_ID=your_app_id
# Your application private key (PKCS1 or PKCS8)
ALIPAY_PRIVATE_KEY=your_private_key
# Alipay public key (not your app public key)
ALIPAY_PUBLIC_KEY=alipay_public_key
# AES key for content encryption (optional)
ALIPAY_ENCRYPT_KEY=
